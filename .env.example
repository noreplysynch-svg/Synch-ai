# ── Core ──────────────────────────────────────────────────────────────────────
# Public URL of the deployed app (Railway gives you this once the service is up,
# e.g. https://synch-ai-production.up.railway.app). Used for OAuth callbacks,
# password-reset links, and uploaded-file URLs.
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=production

# Random long string used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── Database ─────────────────────────────────────────────────────────────────
# Injected automatically once you attach the Postgres plugin in Railway.
# Only needed manually for local dev, e.g.:
#   postgres://postgres:password@localhost:5432/synch_ai
DATABASE_URL=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Email (used for OTP sign-in codes + password reset links) ─────────────────
# Any standard SMTP provider works (Resend, Postmark, SendGrid, Gmail app password, etc).
# If left unset, emails are logged to the server console instead of sent —
# fine for local testing, not for production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Synch AI <no-reply@yourdomain.com>"

# ── OAuth (optional — leave blank to hide/disable that login button) ──────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── File uploads ────────────────────────────────────────────────────────────
# Local path where uploaded files are stored. Attach a Railway Volume mounted
# at this path so uploads survive redeploys (see README).
UPLOAD_DIR=./server/uploads
